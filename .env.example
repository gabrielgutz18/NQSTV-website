# Browser-exposed IDs used by the current static site.
# These help with organization, not secrecy, because the values
# are still visible in client-side code when the site loads.

EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
CRISP_WEBSITE_ID=your_crisp_website_id
